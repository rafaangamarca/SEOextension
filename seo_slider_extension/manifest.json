{
  "manifest_version": 3,
  "name": "SEO Slider Auditor",
  "version": "1.0.0",
  "description": "Panel lateral para revisar una URL con comprobaciones SEO, accesibilidad y presencia técnica.",
  "permissions": [
    "sidePanel",
    "tabs",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "SEO Slider Auditor"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
